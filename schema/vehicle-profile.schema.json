{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "r3LAY Vehicle Profile",
  "description": "Schema for vehicle configuration in ~/.r3lay/vehicles/",
  "type": "object",
  "required": ["vehicle"],
  "properties": {
    "vehicle": {
      "type": "object",
      "required": ["year", "make", "model"],
      "properties": {
        "vin": {
          "type": "string",
          "pattern": "^[A-HJ-NPR-Z0-9]{17}$",
          "description": "17-character VIN (optional)"
        },
        "year": {
          "type": "integer",
          "minimum": 1980,
          "maximum": 2030
        },
        "make": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "trim": {
          "type": "string"
        },
        "engine": {
          "type": "object",
          "properties": {
            "code": {"type": "string"},
            "displacement": {"type": "number"},
            "cylinders": {"type": "integer"},
            "aspiration": {"enum": ["NA", "turbo", "supercharged"]},
            "fuel": {"enum": ["gasoline", "diesel", "electric", "hybrid"]}
          }
        }
      }
    }
  }
}
