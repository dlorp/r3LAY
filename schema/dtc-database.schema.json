{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "r3LAY DTC Database",
  "description": "Schema for diagnostic trouble code databases",
  "type": "object",
  "required": ["schema_version", "codes"],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "manufacturer": {
      "type": "string",
      "description": "For manufacturer-specific codes (P1XXX)"
    },
    "standard": {
      "type": "string",
      "description": "For generic codes (e.g., SAE J2012)"
    },
    "codes": {
      "type": "object",
      "patternProperties": {
        "^P[0-3][0-9A-F]{3}$": {
          "type": "object",
          "required": ["description", "category"],
          "properties": {
            "description": {"type": "string"},
            "category": {
              "enum": [
                "fuel_air_metering",
                "ignition",
                "emissions",
                "speed_idle",
                "computer",
                "transmission",
                "electrical",
                "cooling",
                "system"
              ]
            },
            "common_causes": {
              "type": "array",
              "items": {"type": "string"}
            }
          }
        }
      }
    }
  }
}
