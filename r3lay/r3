#!/bin/bash
# r3 -- speak with your projects
# Install: chmod +x r3lay/r3 && sudo ln -s $(pwd)/r3lay/r3 /usr/local/bin/r3
#
# Self-contained: auto-detects the r3LAY repo via the script's real path,
# sets PYTHONPATH, and uses a venv if one exists at <repo>/.venv.
# Works from anywhere without requiring `pip install -e .`.

PROFILE="r3lay"

# Resolve the script's real path (follows symlinks like /usr/local/bin/r3)
SOURCE="$0"
while [ -L "$SOURCE" ]; do
    DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# Make the r3lay package importable from anywhere
export PYTHONPATH="$REPO_DIR:${PYTHONPATH:-}"

# Prefer the repo's venv Python if it exists
if [ -x "$REPO_DIR/.venv/bin/python3" ]; then
    PYTHON="$REPO_DIR/.venv/bin/python3"
else
    PYTHON="$(command -v python3)"
fi

# Load the bridge API secret so child processes (curl, skills) can authenticate.
# Precedence: existing env var > ~/.r3lay/api-secret file
if [ -z "${R3LAY_API_KEY:-}" ] && [ -r "$HOME/.r3lay/api-secret" ]; then
    R3LAY_API_KEY="$(cat "$HOME/.r3lay/api-secret")"
    export R3LAY_API_KEY
fi

# Bridge URL — overridable so the Hermes Docker sandbox can target
# host.docker.internal:8765 via the R3LAY_BRIDGE_URL env var while host
# shells keep using localhost.
BRIDGE_URL="${R3LAY_BRIDGE_URL:-http://localhost:8765}"

# Helper: join remaining args (from $2 onward) into a single space-separated
# string while preserving the original argument boundaries.
join_rest() {
    shift  # drop the subcommand name ($1)
    if [ $# -eq 0 ]; then
        printf ''
    else
        printf '%s' "$1"
        shift
        printf ' %s' "$@"
    fi
}

# Helper: assert the API key is present before any bridge call.
_require_key() {
    if [ -z "${R3LAY_API_KEY:-}" ]; then
        echo "error: R3LAY_API_KEY not set and ~/.r3lay/api-secret unreadable" >&2
        echo "hint: start r3 up once on the host to auto-generate the secret" >&2
        exit 2
    fi
}

# Helper: build a JSON body from key/value pairs via python3 for correct escaping.
# Usage: _json path /foo auto_index true notes "optional message"
_json() {
    python3 - "$@" <<'PY'
import json, sys
args = sys.argv[1:]
out = {}
for i in range(0, len(args), 2):
    k = args[i]
    v = args[i + 1] if i + 1 < len(args) else ""
    if v == "":
        out[k] = None
    elif v in ("true", "false"):
        out[k] = (v == "true")
    else:
        out[k] = v
print(json.dumps(out))
PY
}

# Helper: POST a JSON body to a bridge endpoint and surface the response.
_bridge_post() {
    _require_key
    local endpoint="$1"
    local body="$2"
    curl -fsS -X POST "${BRIDGE_URL}${endpoint}" \
        -H 'Content-Type: application/json' \
        -H "X-R3LAY-Key: ${R3LAY_API_KEY}" \
        -d "$body"
    echo
}

_bridge_get() {
    _require_key
    local endpoint="$1"
    curl -fsS "${BRIDGE_URL}${endpoint}" \
        -H "X-R3LAY-Key: ${R3LAY_API_KEY}"
    echo
}

_bridge_delete() {
    _require_key
    local endpoint="$1"
    curl -fsS -X DELETE "${BRIDGE_URL}${endpoint}" \
        -H "X-R3LAY-Key: ${R3LAY_API_KEY}"
    echo
}

case "$1" in
  # Context commands (r3c is alias for r3-context)
  r3c|r3-context|context)
    hermes --profile "$PROFILE" chat "/r3-context ${2:-}"
    ;;
  # Planning mode (r3p is alias for r3-plan)
  r3p|r3-plan|plan)
    hermes --profile "$PROFILE" chat "/r3-plan ${2:-}"
    ;;
  # Session management
  sn)
    hermes --profile "$PROFILE" chat "/sn"
    ;;
  session)
    hermes --profile "$PROFILE" chat "/session ${2:-}"
    ;;
  # Research
  research)
    args="$(join_rest "$@")"
    hermes --profile "$PROFILE" chat "/research $args"
    ;;
  # Project health (chat-driven — summarizes a specific project)
  status|health)
    hermes --profile "$PROFILE" chat "/health"
    ;;
  # System-level doctor — runs all probes against DB + embedding + pipeline
  # state. Pretty-prints worst-first so problems are visible at a glance.
  doctor)
    # Optional --offline skips the network-dependent model probes.
    network="true"
    [ "${2:-}" = "--offline" ] && network="false"
    _require_key
    # Capture both body and status so a dead bridge / new route missing
    # produces a useful message instead of an empty-stdin JSON crash.
    tmp=$(mktemp -t r3doctor)
    trap 'rm -f "$tmp"' EXIT
    code=$(curl -sS -o "$tmp" -w '%{http_code}' \
        "${BRIDGE_URL}/doctor?include_network=${network}" \
        -H "X-R3LAY-Key: ${R3LAY_API_KEY}" 2>&1) || true
    if [ -z "$code" ] || [ "$code" = "000" ]; then
        echo "[FAIL] bridge not reachable at ${BRIDGE_URL}" >&2
        echo "       start it with: r3 up" >&2
        exit 2
    fi
    if [ "$code" = "404" ]; then
        echo "[FAIL] /doctor route missing — bridge is running old code" >&2
        echo "       restart with: r3 up" >&2
        exit 2
    fi
    if [ "$code" != "200" ]; then
        echo "[FAIL] bridge returned HTTP $code" >&2
        cat "$tmp" >&2
        exit 2
    fi
    python3 -c '
import json, sys
data = json.load(sys.stdin)
overall = data.get("overall_status", "unknown").upper()
icon = {"OK": "[OK]", "WARN": "[WARN]", "FAIL": "[FAIL]"}.get(overall, "[??]")
checked = data.get("checked_at", "")
print(f"{icon} Overall: {overall}")
print(f"    Checked at: {checked}")
print()
for c in data.get("checks", []):
    s = c["status"].upper()
    tag = {"OK": "  ok  ", "WARN": " warn ", "FAIL": " FAIL "}.get(s, "  ??  ")
    name = c["name"]
    msg = c["message"]
    print(f"[{tag}] {name:24s} {msg}")
' < "$tmp"
    ;;
  # Raw pipeline status JSON (stuck runs, failures, per-pipeline counts).
  pipeline-status)
    lookback="${2:-60}"
    _bridge_get "/pipeline/status?lookback_minutes=${lookback}"
    ;;
  # Destructive regression gate: wipe DB, re-ingest from filesystem, diff.
  # Only use when the watcher is stopped. Backup is restored on failure.
  rebuild)
    case "${2:-}" in
      --verify)
        keep="false"
        [ "${3:-}" = "--keep-backup" ] && keep="true"
        echo "WARNING: this wipes the DB and re-ingests. Confirm the watcher"
        echo "         is not running (pgrep -f r3lay.sync should be empty)."
        printf "Type 'verify' to proceed: "
        read -r answer
        if [ "$answer" != "verify" ]; then
          echo "aborted"
          exit 1
        fi
        _require_key
        tmp=$(mktemp -t r3rebuild)
        trap 'rm -f "$tmp"' EXIT
        code=$(curl -sS -o "$tmp" -w '%{http_code}' -X POST \
          "${BRIDGE_URL}/verify-rebuild?keep_backup=${keep}" \
          -H "X-R3LAY-Key: ${R3LAY_API_KEY}" 2>&1) || true
        if [ -z "$code" ] || [ "$code" = "000" ]; then
          echo "[FAIL] bridge not reachable at ${BRIDGE_URL}" >&2
          echo "       start it with: r3 up" >&2
          exit 2
        fi
        if [ "$code" = "404" ]; then
          echo "[FAIL] /verify-rebuild route missing — bridge is running old code" >&2
          echo "       restart with: r3 up" >&2
          exit 2
        fi
        if [ "$code" != "200" ]; then
          echo "[FAIL] bridge returned HTTP $code" >&2
          cat "$tmp" >&2
          exit 2
        fi
        python3 -c '
import json, sys
r = json.load(sys.stdin)
status = "PASS" if r.get("success") else "FAIL"
projects = r.get("rebuilt_projects", 0)
files = r.get("rebuilt_files", 0)
chunks = r.get("rebuilt_chunks", 0)
print(f"[{status}] rebuild verify")
print(f"    projects={projects}  files={files}  chunks={chunks}")
if r.get("restored_from_backup"):
    print("    original DB restored from backup")
err = r.get("error")
if err:
    print(f"    error: {err}")
print()
before = r.get("before_counts", {})
after = r.get("after_counts", {})
keys = sorted(set(before) | set(after))
for t in keys:
    b = before.get(t, 0)
    a = after.get(t, 0)
    if b or a:
        delta = a - b
        sign = "+" if delta > 0 else ""
        print(f"    {t:18s}  before={b:<6d}  after={a:<6d}  ({sign}{delta})")
missing = r.get("missing_rebuildable", {})
if missing:
    print()
    print("  MISSING after rebuild:")
    for t, ids in missing.items():
        sample = ids[:3]
        print(f"    {t}: {len(ids)} rows — sample: {sample}")
orphaned = r.get("orphaned_db_only", {})
if orphaned:
    print()
    print("  DB-only state (would be lost on true wipe):")
    for t, n in orphaned.items():
        print(f"    {t}: {n} rows")
    print("  ^ filesystem-is-truth gap — these tables need persistence work")
' < "$tmp"
        ;;
      *)
        echo "Usage: r3 rebuild --verify [--keep-backup]" >&2
        exit 2
        ;;
    esac
    ;;
  # Conflicts
  conflicts)
    hermes --profile "$PROFILE" chat "/conflicts"
    ;;
  # Todos
  todos)
    hermes --profile "$PROFILE" chat "/todos ${2:-}"
    ;;
  # PR workflow
  pr)
    args="$(join_rest "$@")"
    hermes --profile "$PROFILE" chat "/pr $args"
    ;;
  # Services
  serve)
    "$PYTHON" -m r3lay.bridge
    ;;
  watch)
    "$PYTHON" -m r3lay.sync
    ;;
  up)
    # Launch services in tmux splits
    bash "$REPO_DIR/launchd/r3lay-up.sh"
    ;;
  # Index a project. `--fresh` bypasses the content-hash skip so every file
  # is re-chunked and re-embedded; use after changing the embedding model
  # or chunker. The env var is read inside ingest.py via cache.py.
  index)
    path="${2:-.}"
    fresh="${3:-}"
    if [ "$fresh" = "--fresh" ] || [ "$fresh" = "--no-cache" ]; then
      R3LAY_NO_CACHE=1 "$PYTHON" -m r3lay.ingest "$path"
    else
      "$PYTHON" -m r3lay.ingest "$path"
    fi
    ;;
  # Search
  search)
    args="$(join_rest "$@")"
    "$PYTHON" -m r3lay.search "$args"
    ;;
  # ──────────────────────────────────────────────────────────
  # Tracked-path subcommands — shell-wrapped bridge calls.
  # These fire Hermes's built-in approval TUI when called via
  # the terminal tool from inside the Docker sandbox.
  # ──────────────────────────────────────────────────────────
  tracked|list-tracked)
    # GET /tracked — list all tracked paths (read-only, safe)
    _bridge_get "/tracked"
    ;;
  track)
    # r3 track <path> [--no-index] [notes...]
    target="${2:-}"
    if [ -z "$target" ]; then
        echo "Usage: r3 track <path> [--no-index] [notes...]" >&2
        exit 2
    fi
    shift 2
    auto_index="true"
    if [ "${1:-}" = "--no-index" ]; then
        auto_index="false"
        shift
    fi
    notes=""
    if [ $# -gt 0 ]; then
        notes="$*"
    fi
    body="$(_json path "$target" auto_index "$auto_index" notes "$notes")"
    _bridge_post "/tracked" "$body"
    ;;
  untrack)
    # r3 untrack <id>
    tid="${2:-}"
    if [ -z "$tid" ]; then
        echo "Usage: r3 untrack <tracked_id>" >&2
        echo "hint: run 'r3 tracked' to list ids" >&2
        exit 2
    fi
    _bridge_delete "/tracked/$tid"
    ;;
  reindex)
    # r3 reindex <id>
    tid="${2:-}"
    if [ -z "$tid" ]; then
        echo "Usage: r3 reindex <tracked_id>" >&2
        exit 2
    fi
    body="$(_json tracked_id "$tid")"
    _bridge_post "/reindex" "$body"
    ;;
  git-check)
    # r3 git-check <id> — read-only, runs git fetch
    tid="${2:-}"
    if [ -z "$tid" ]; then
        echo "Usage: r3 git-check <tracked_id>" >&2
        exit 2
    fi
    body="$(_json tracked_id "$tid")"
    _bridge_post "/git/check" "$body"
    ;;
  git-pull)
    # r3 git-pull <id> — MUTATING, bridge enforces clean tree
    tid="${2:-}"
    if [ -z "$tid" ]; then
        echo "Usage: r3 git-pull <tracked_id>" >&2
        exit 2
    fi
    body="$(_json tracked_id "$tid")"
    _bridge_post "/git/pull" "$body"
    ;;
  # Empty -- open interactive session
  "")
    hermes --profile "$PROFILE" chat
    ;;
  # Default -- project/message routing
  *)
    if [ -d "$HOME/r3LAY/$1" ] && [ -n "${2:-}" ]; then
      project="$1"
      args="$(join_rest "$@")"
      hermes --profile "$PROFILE" chat "Project: $project. $args"
    else
      hermes --profile "$PROFILE" chat "$*"
    fi
    ;;
esac
